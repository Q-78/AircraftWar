<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="edu.hitsz.application.ModeChoose">
  <grid id="27dc6" binding="mainPanel" layout-manager="GridLayoutManager" row-count="6" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="40" left="50" bottom="40" right="50"/>
    <constraints>
      <xy x="20" y="20" width="500" height="700"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <component id="title" class="javax.swing.JLabel">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <font size="28" style="1"/>
          <horizontalAlignment value="0"/>
          <text value="请选择游戏难度"/>
        </properties>
      </component>
      <vspacer id="spacer1">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
        </constraints>
      </vspacer>
      <component id="easy" class="javax.swing.JButton" binding="easyModeButton">
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties><font size="20"/><text value="简单模式"/></properties>
      </component>
      <component id="normal" class="javax.swing.JButton" binding="normalModeButton">
        <constraints>
          <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties><font size="20"/><text value="普通模式"/></properties>
      </component>
      <component id="hard" class="javax.swing.JButton" binding="hardModeButton">
        <constraints>
          <grid row="4" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties><font size="20"/><text value="困难模式"/></properties>
      </component>
      <component id="instruction" class="javax.swing.JButton" binding="instructionButton">
        <constraints>
          <grid row="5" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties><font size="20"/><text value="操作说明"/></properties>
      </component>
    </children>
  </grid>
</form>
